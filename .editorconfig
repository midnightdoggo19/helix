root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{c,h}]
indent_style = space
indent_size = 4

[*.asm]
indent_style = space
indent_size = 4

[*.{md,mmd}]
trim_trailing_whitespace = false  # markdown line-break has trailing spaces

[Makefile]
indent_style = tab

[*.sh]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2
